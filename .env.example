DATABASE_URL=postgres://postgres:postgres@localhost:5432/todo_gameification
BETTER_AUTH_SECRET=replace-with-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# Generate with: pnpm dlx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional: LLM-assigned XP scoring (OpenAI-compatible endpoint, e.g. LM Studio).
# Leave blank to skip auto-scoring; tasks then use the difficulty-based default.
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# Comma-separated list of emails that can access /admin. Matching is
# case-insensitive. Empty string (or missing var) means no one is admin.
ADMIN_EMAILS=
